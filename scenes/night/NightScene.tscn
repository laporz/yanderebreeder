[gd_scene load_steps=5 format=3]

[ext_resource type="Script" path="res://scenes/night/NightScene.gd" id="1"]
[ext_resource type="PackedScene" path="res://scenes/components/CharacterView.tscn" id="2"]
[ext_resource type="PackedScene" path="res://scenes/components/DialogueBox.tscn" id="3"]
[ext_resource type="PackedScene" path="res://scenes/components/SavePanel.tscn" id="4"]

[node name="NightScene" type="Node"]
script = ExtResource("1")

[node name="CharacterView" parent="." instance=ExtResource("2")]

[node name="DialogueBox" parent="." instance=ExtResource("3")]

[node name="SavePanel" parent="." instance=ExtResource("4")]

[node name="CanvasLayer" type="CanvasLayer" parent="."]

[node name="VBox" type="VBoxContainer" parent="CanvasLayer"]
anchor_right = 1.0
anchor_bottom = 1.0
offset_left = 420.0

[node name="SceneTitle" type="Label" parent="CanvasLayer/VBox"]
text = "🌙 夜のひととき"
theme_override_font_sizes/font_size = 24

[node name="StatusLabel" type="Label" parent="CanvasLayer/VBox"]
text = ""
theme_override_font_sizes/font_size = 14

[node name="ResultLabel" type="Label" parent="CanvasLayer/VBox"]
text = ""
theme_override_colors/font_color = Color(0.9, 0.4, 0.6, 1)

[node name="MainPanel" type="VBoxContainer" parent="CanvasLayer/VBox"]

[node name="DrugstoreButton" type="Button" parent="CanvasLayer/VBox/MainPanel"]
text = "💊 ドラッグストアで買い物"

[node name="YamizonButton" type="Button" parent="CanvasLayer/VBox/MainPanel"]
text = "📦 Yamizonで買い物"

[node name="BathButton" type="Button" parent="CanvasLayer/VBox/MainPanel"]
text = "🛁 お風呂に入る"

[node name="MealButton" type="Button" parent="CanvasLayer/VBox/MainPanel"]
text = "🍽️ ご飯を食べる（好感度 +1）"

[node name="TalkButton" type="Button" parent="CanvasLayer/VBox/MainPanel"]
text = "💬 会話する"

[node name="TouchButton" type="Button" parent="CanvasLayer/VBox/MainPanel"]
text = "🤝 ふれあう"

[node name="SaveButton" type="Button" parent="CanvasLayer/VBox/MainPanel"]
text = "💾 セーブ"

[node name="SleepButton" type="Button" parent="CanvasLayer/VBox/MainPanel"]
text = "💤 寝る"

[node name="TouchPanel" type="VBoxContainer" parent="CanvasLayer/VBox"]
visible = false

[node name="TouchLabel" type="Label" parent="CanvasLayer/VBox/TouchPanel"]
text = "どこに触れますか？"

[node name="TouchBackButton" type="Button" parent="CanvasLayer/VBox/TouchPanel"]
text = "← 戻る"

[connection signal="pressed" from="CanvasLayer/VBox/MainPanel/DrugstoreButton" to="." method="_on_drugstore_pressed"]
[connection signal="pressed" from="CanvasLayer/VBox/MainPanel/YamizonButton" to="." method="_on_yamizon_pressed"]
[connection signal="pressed" from="CanvasLayer/VBox/MainPanel/BathButton" to="." method="_on_bath_pressed"]
[connection signal="pressed" from="CanvasLayer/VBox/MainPanel/MealButton" to="." method="_on_meal_pressed"]
[connection signal="pressed" from="CanvasLayer/VBox/MainPanel/TalkButton" to="." method="_on_talk_pressed"]
[connection signal="pressed" from="CanvasLayer/VBox/MainPanel/TouchButton" to="." method="_on_touch_pressed"]
[connection signal="pressed" from="CanvasLayer/VBox/MainPanel/SaveButton" to="." method="_on_save_button_pressed"]
[connection signal="pressed" from="CanvasLayer/VBox/MainPanel/SleepButton" to="." method="_on_sleep_pressed"]
[connection signal="pressed" from="CanvasLayer/VBox/TouchPanel/TouchBackButton" to="." method="_on_touch_back_pressed"]
