theme_override_font_sizes/font_size = 48

[node name="SubLabel" type="Label" parent="CanvasLayer/VBox"]
text = "— ヒロインとの日常をすごそう —"
horizontal_alignment = 1
theme_override_font_sizes/font_size = 18

[node name="Spacer" type="Control" parent="CanvasLayer/VBox"]
